{
  "name": "chess",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open",
    "start:host": "ng serve --host 192.168.1.1",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format": "prettier --write \"**/*\" --ignore-unknown",
    "format:check": "prettier --check \"**/*\" --ignore-unknown",
    "lint": "ng lint",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "lint:scss": "stylelint '**/*.{css,scss}'",
    "lint:scss:fix": "stylelint '**/*.{css,scss}' --fix",
    "prepare": "husky"
  },
  "private": true,
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular/animations": "^20.2.4",
    "@angular/common": "20.2.4",
    "@angular/compiler": "20.2.4",
    "@angular/core": "20.2.4",
