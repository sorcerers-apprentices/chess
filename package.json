    "@taiga-ui/addon-doc": "^4.52.0",
    "@taiga-ui/addon-mobile": "^4.52.0",
    "@taiga-ui/addon-table": "^4.52.0",
    "@taiga-ui/cdk": "^4.52.0",
    "@taiga-ui/core": "^4.52.0",
    "@taiga-ui/experimental": "^4.52.0",
    "@taiga-ui/icons": "^4.52.0",
    "@taiga-ui/kit": "^4.52.0",
    "@taiga-ui/layout": "^4.52.0",
    "@taiga-ui/styles": "^4.52.0",
    "rxjs": "~7.8.0"
